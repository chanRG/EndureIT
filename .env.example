# EndureIT - Root Environment Configuration
# This file contains infrastructure-level settings used by docker-compose.yml
# Copy this to .env and update with your actual values

# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# =============================================================================
POSTGRES_USER=endureit_user
POSTGRES_PASSWORD=change_this_to_a_secure_password
POSTGRES_DB=endureit_db

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================
# Generate a secure key with: openssl rand -hex 32
SECRET_KEY=change_this_to_a_random_secret_key_generate_with_openssl

# CORS Origins (comma-separated list of allowed origins)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# =============================================================================
# ENVIRONMENT SETTINGS
# =============================================================================
ENVIRONMENT=development
DEBUG=true

# =============================================================================
# STRAVA API
# =============================================================================
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_ACCESS_TOKEN=your_strava_access_token
STRAVA_REFRESH_TOKEN=your_strava_refresh_token

# =============================================================================
# ANTHROPIC / CLAUDE
# =============================================================================
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-changeme
CLAUDE_MODEL_DEFAULT=claude-sonnet-4-6
CLAUDE_MODEL_HEAVY=claude-opus-4-7

# =============================================================================
# WEB PUSH (VAPID)
# =============================================================================
# Generate keys with vapid CLI (installed via pywebpush):
#   vapid --gen
# This produces private_key.pem and public_key.pem; convert with:
#   vapid --applicationServerKey   (prints the URL-safe base64 public key)
# Or with Python:
#   python -c "
#   from cryptography.hazmat.primitives.asymmetric import ec
#   from cryptography.hazmat.backends import default_backend
#   import base64, json
#   key = ec.generate_private_key(ec.SECP256R1(), default_backend())
#   priv = base64.urlsafe_b64encode(key.private_bytes_raw()).decode()
#   pub  = base64.urlsafe_b64encode(key.public_key().public_bytes_raw()).decode()
#   print('VAPID_PRIVATE_KEY=' + priv); print('VAPID_PUBLIC_KEY=' + pub)
#   "
VAPID_PUBLIC_KEY=changeme_base64url_public_key
VAPID_PRIVATE_KEY=changeme_base64url_private_key
VAPID_SUBJECT=mailto:admin@yourdomain.com

# =============================================================================
# EMAIL (SMTP — optional, used as fallback for critical reminders)
# =============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@yourdomain.com
EMAILS_FROM_NAME=EndureIT

# =============================================================================
# TOKEN ENCRYPTION (Strava tokens at rest)
# =============================================================================
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=changeme_fernet_key

# =============================================================================
# UPLOADS
# =============================================================================
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# =============================================================================
# INSTRUCTIONS
# =============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Generate a secure SECRET_KEY:
#    openssl rand -hex 32
# 3. Update POSTGRES_PASSWORD with a strong password
# 4. Update BACKEND_CORS_ORIGINS with your frontend URL(s)
#
# For production:
# - Set ENVIRONMENT=production
# - Set DEBUG=false
# - Use strong passwords and keys
# - Update CORS origins to production URLs only
