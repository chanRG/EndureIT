# EndureIT - Root .gitignore

# Environment variables
.env
.env.local
.env.*.local
*.env
!.env.example
secrets/
*.secret

# Claude Code / AI tooling (never commit)
.claude/
.aider*
.cursor/

# Database
*.db
*.sqlite
*.sqlite3
postgres_data/
redis_data/

# Docker
docker-compose.override.yml.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*~

# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.project
.pydevproject
.settings/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
!frontend/src/lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
venv/
env/
ENV/

# Node / JavaScript
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
dist/
build/
.next/
out/
.nuxt/
.cache/
.parcel-cache/

# Testing
coverage/
.nyc_output/

# Temporary files
*.tmp
*.temp
*.bak
*.backup
*.swp
*.swo

# Backups
backup_*.sql
*.sql
!backend/migrations/*.sql

# SSL Certificates (keep examples, ignore actual certs)
*.key
*.crt
*.pem
!example.key
!example.crt

# Application specific
uploads/
media/
static/collected_static/

